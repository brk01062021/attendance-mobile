{
  "expo": {
    "name": "VidyaSetu",
    "slug": "attendance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon.png",
    "scheme": "attendancemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#061B33",
        "foregroundImage": "./assets/branding/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/branding/app-icon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/splash-bg.png",
          "resizeMode": "cover",
          "backgroundColor": "#061B33",
          "dark": {
            "image": "./assets/branding/splash-bg.png",
            "resizeMode": "cover",
            "backgroundColor": "#061B33"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}